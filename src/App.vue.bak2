              <path d="M8 12l3 3 5-5" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <div class="bottom-bar">
      <div class="bottom-left">
        <div class="bottom-amount-label">待支付</div>
        <div class="bottom-amount">¥<span class="amount-big">{{ displayAmount.split('.')[0] }}</span>.<span class="amount-decimal">{{ displayAmount.split('.')[1] }}</span></div>
      </div>
      <button class="pay-btn" @click="handlePay">
        立即支付
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" style="margin-left:4px">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
