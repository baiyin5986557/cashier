              </svg>
            </div>
            <div>
              <div class="pay-method-name">微信支付</div>
              <div class="pay-method-desc">推荐使用，安全快捷</div>
            </div>
          </div>
          <div class="pay-method-checked">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
