  <!-- ====== 用户扫码付款页（原有的支付页） ====== -->
  <div class="payment-page" v-if="page === 'userPay'">
    <div class="top-curve"></div>
    <div class="header" @click="page='home'">
      <span class="header-back">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
